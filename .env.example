# ─────────────────────────────────────────────
# Vapi Configuration
# ─────────────────────────────────────────────

# Your Vapi API key (from dashboard.vapi.ai → Account → API Keys)
VAPI_API_KEY=

# Sarah's assistant ID (from dashboard.vapi.ai → Assistants → select assistant → copy ID)
VAPI_ASSISTANT_ID=

# Secret used to verify the HMAC-SHA256 signature Vapi sends on every webhook
# request. Set this in the Vapi dashboard under Server URL → Secret.
VAPI_WEBHOOK_SECRET=

# ─────────────────────────────────────────────
# Twilio Configuration
# ─────────────────────────────────────────────

# Twilio Account SID (from console.twilio.com → Account Info)
TWILIO_ACCOUNT_SID=

# Twilio Auth Token (from console.twilio.com → Account Info)
TWILIO_AUTH_TOKEN=

# Twilio phone number to send SMS from (E.164 format, e.g. +15005550006)
TWILIO_FROM_NUMBER=

# Shop owner's phone number to receive SMS summaries (E.164 format, e.g. +15551234567)
SHOP_OWNER_PHONE=

# ─────────────────────────────────────────────
# Supabase Configuration
# ─────────────────────────────────────────────

# Supabase project URL (from app.supabase.com → Project Settings → API)
SUPABASE_URL=

# Supabase service role key — keep this secret, never expose to the browser
# (from app.supabase.com → Project Settings → API → service_role key)
SUPABASE_SERVICE_KEY=

# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────

# Public base URL of this deployment (no trailing slash)
# Used to construct callback URLs when registering assistants, etc.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

