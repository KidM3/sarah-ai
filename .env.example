# ─────────────────────────────────────────────
# Vapi Configuration
# ─────────────────────────────────────────────

# Your Vapi API key (from dashboard.vapi.ai → Account → API Keys)
VAPI_API_KEY=

# Secret used to verify the HMAC-SHA256 signature Vapi sends on every webhook
# request. Set this in the Vapi dashboard under Server URL → Secret.
VAPI_WEBHOOK_SECRET=

# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────

# Public base URL of this deployment (no trailing slash)
# Used to construct callback URLs when registering assistants, etc.
NEXT_PUBLIC_BASE_URL=http://localhost:3000
